п»ҝ// Р СҹРЎРӮР С‘Р СҳР ВөРЎРӮ Unit-РЎвҖҡР ВөРЎРғРЎвҖҡР С•Р РҶ Р Т‘Р В»РЎРҸ FileChecker
// Р вҖқР В»РЎРҸ Р С‘РЎРғР С—Р С•Р В»РЎРҠР В·Р С•Р РҶР В°Р Р…Р С‘РЎРҸ Р Р…Р ВөР С•Р ВұРЎвҖҰР С•Р Т‘Р С‘Р СҳР С• РЎРғР С•Р В·Р Т‘Р В°РЎвҖҡРЎРҠ РЎвҖҡР ВөРЎРғРЎвҖҡР С•Р РҶРЎвҖ№Р в„– Р С—РЎРӮР С•Р ВөР С”РЎвҖҡ Р С‘ Р Т‘Р С•Р ВұР В°Р РҶР С‘РЎвҖҡРЎРҠ NuGet Р С—Р В°Р С”Р ВөРЎвҖҡРЎвҖ№:
// - NUnit Р С‘Р В»Р С‘ xUnit
// - NUnit3TestAdapter
// - Microsoft.NET.Test.Sdk

using NUnit.Framework;

namespace PairChecker.Tests;

[TestFixture]
public class FileCheckerTests
{
    private string testFolder = string.Empty;

    [SetUp]
    public void Setup()
    {
        // Р РҺР С•Р В·Р Т‘Р В°Р ВөР Сҳ Р РҶРЎРӮР ВөР СҳР ВөР Р…Р Р…РЎС“РЎРӢ Р С—Р В°Р С—Р С”РЎС“ Р Т‘Р В»РЎРҸ РЎвҖҡР ВөРЎРғРЎвҖҡР С•Р РҶ
        testFolder = Path.Combine(Path.GetTempPath(), "PairCheckerTests", Guid.NewGuid().ToString());
        Directory.CreateDirectory(testFolder);
    }

    [TearDown]
    public void Cleanup()
    {
        // Р РҲР Т‘Р В°Р В»РЎРҸР ВөР Сҳ Р РҶРЎРӮР ВөР СҳР ВөР Р…Р Р…РЎС“РЎРӢ Р С—Р В°Р С—Р С”РЎС“ Р С—Р С•РЎРғР В»Р Вө РЎвҖҡР ВөРЎРғРЎвҖҡР С•Р РҶ
        if (Directory.Exists(testFolder))
        {
            Directory.Delete(testFolder, true);
        }
    }

    [Test]
    public async Task CheckFiles_WithMatchingPairs_ShouldReturnNoUnpairedFiles()
    {
        // Arrange
        CreateTestFile("document1.pdf");
        CreateTestFile("document1.dxf");
        CreateTestFile("document2.pdf");
        CreateTestFile("document2.dxf");

        var checker = new FileChecker();

        // Act
        var result = await checker.CheckFilesAsync(testFolder, ".pdf", ".dxf", false);

        // Assert
        Assert.That(result.FirstWithoutPair.Count, Is.EqualTo(0));
        Assert.That(result.SecondWithoutPair.Count, Is.EqualTo(0));
        Assert.That(result.TotalFirstFiles, Is.EqualTo(2));
        Assert.That(result.TotalSecondFiles, Is.EqualTo(2));
    }

    [Test]
    public async Task CheckFiles_WithUnpairedFiles_ShouldFindThem()
    {
        // Arrange
        CreateTestFile("document1.pdf");
        CreateTestFile("document1.dxf");
        CreateTestFile("document2.pdf"); // Р вҖҳР ВөР В· Р С—Р В°РЎРӮРЎвҖ№
        CreateTestFile("document3.dxf"); // Р вҖҳР ВөР В· Р С—Р В°РЎРӮРЎвҖ№

        var checker = new FileChecker();

        // Act
        var result = await checker.CheckFilesAsync(testFolder, ".pdf", ".dxf", false);

        // Assert
        Assert.That(result.FirstWithoutPair.Values.Sum(v => v.Count), Is.EqualTo(1));
        Assert.That(result.SecondWithoutPair.Values.Sum(v => v.Count), Is.EqualTo(1));
    }

    [Test]
    public async Task CheckFiles_Recursive_ShouldFindFilesInSubfolders()
    {
        // Arrange
        var subFolder = Path.Combine(testFolder, "subfolder");
        Directory.CreateDirectory(subFolder);

        CreateTestFile("document1.pdf");
        CreateTestFile("document1.dxf");
        CreateTestFile(Path.Combine("subfolder", "document2.pdf"));
        CreateTestFile(Path.Combine("subfolder", "document2.dxf"));

        var checker = new FileChecker();

        // Act
        var result = await checker.CheckFilesAsync(testFolder, ".pdf", ".dxf", true);

        // Assert
        Assert.That(result.TotalFirstFiles, Is.EqualTo(2));
        Assert.That(result.TotalSecondFiles, Is.EqualTo(2));
    }

    [Test]
    public async Task CheckFiles_NonRecursive_ShouldIgnoreSubfolders()
    {
        // Arrange
        var subFolder = Path.Combine(testFolder, "subfolder");
        Directory.CreateDirectory(subFolder);

        CreateTestFile("document1.pdf");
        CreateTestFile("document1.dxf");
        CreateTestFile(Path.Combine("subfolder", "document2.pdf"));
        CreateTestFile(Path.Combine("subfolder", "document2.dxf"));

        var checker = new FileChecker();

        // Act
        var result = await checker.CheckFilesAsync(testFolder, ".pdf", ".dxf", false);

        // Assert
        Assert.That(result.TotalFirstFiles, Is.EqualTo(1));
        Assert.That(result.TotalSecondFiles, Is.EqualTo(1));
    }

    [Test]
    public void CheckFiles_WithInvalidFolder_ShouldThrowException()
    {
        // Arrange
        var checker = new FileChecker();
        var invalidFolder = Path.Combine(Path.GetTempPath(), Guid.NewGuid().ToString());

        // Act & Assert
        Assert.ThrowsAsync<DirectoryNotFoundException>(async () =>
            await checker.CheckFilesAsync(invalidFolder, ".pdf", ".dxf", false));
    }

    [Test]
    public async Task CheckFiles_WithCancellation_ShouldThrowOperationCanceledException()
    {
        // Arrange
        CreateManyTestFiles(1000); // Р РҺР С•Р В·Р Т‘Р В°Р ВөР Сҳ Р СҳР Р…Р С•Р С–Р С• РЎвҖһР В°Р в„–Р В»Р С•Р РҶ Р Т‘Р В»РЎРҸ Р Т‘Р В»Р С‘РЎвҖҡР ВөР В»РЎРҠР Р…Р С•Р в„– Р С•Р С—Р ВөРЎРӮР В°РЎвҖ Р С‘Р С‘
        var checker = new FileChecker();
        var cts = new CancellationTokenSource();

        // Act
        var task = checker.CheckFilesAsync(testFolder, ".pdf", ".dxf", false, cts.Token);
        cts.Cancel(); // Р СӣРЎвҖҡР СҳР ВөР Р…РЎРҸР ВөР Сҳ Р С•Р С—Р ВөРЎРӮР В°РЎвҖ Р С‘РЎРӢ

        // Assert
        Assert.ThrowsAsync<OperationCanceledException>(async () => await task);
    }

    [Test]
    public async Task GenerateReport_ShouldContainAllSections()
    {
        // Arrange
        CreateTestFile("document1.pdf");
        CreateTestFile("document2.dxf");

        var checker = new FileChecker();
        var result = await checker.CheckFilesAsync(testFolder, ".pdf", ".dxf", false);

        // Act
        var report = FileChecker.GenerateReport(result, ".pdf", ".dxf");

        // Assert
        Assert.That(report, Does.Contain("Р ВӨР С’Р в„ўР вҖәР В« Р вҖҳР вҖўР вҖ” Р СҹР С’Р В Р В«"));
        Assert.That(report, Does.Contain("Р РҺР СһР С’Р СһР ВҳР РҺР СһР ВҳР СҷР С’"));
        Assert.That(report, Does.Contain(".PDF Р ВұР ВөР В· .DXF Р С—Р В°РЎРӮРЎвҖ№"));
        Assert.That(report, Does.Contain(".DXF Р ВұР ВөР В· .PDF Р С—Р В°РЎРӮРЎвҖ№"));
    }

    [Test]
    public async Task CheckFiles_ProgressEvent_ShouldBeRaised()
    {
        // Arrange
        CreateTestFile("document1.pdf");
        CreateTestFile("document1.dxf");

        var checker = new FileChecker();
        var progressEvents = new List<ProgressEventArgs>();
        checker.ProgressChanged += (sender, e) => progressEvents.Add(e);

        // Act
        await checker.CheckFilesAsync(testFolder, ".pdf", ".dxf", false);

        // Assert
        Assert.That(progressEvents.Count, Is.GreaterThan(0));
        Assert.That(progressEvents.Any(e => e.Percentage == 100), Is.True);
    }

    private void CreateTestFile(string relativePath)
    {
        var fullPath = Path.Combine(testFolder, relativePath);
        var directory = Path.GetDirectoryName(fullPath);
        if (!string.IsNullOrEmpty(directory) && !Directory.Exists(directory))
        {
            Directory.CreateDirectory(directory);
        }
        File.WriteAllText(fullPath, "test content");
    }

    private void CreateManyTestFiles(int count)
    {
        for (int i = 0; i < count; i++)
        {
            CreateTestFile($"document{i}.pdf");
            if (i % 2 == 0)
            {
                CreateTestFile($"document{i}.dxf");
            }
        }
    }
}

[TestFixture]
public class AppSettingsTests
{
    private string testSettingsPath = string.Empty;

    [SetUp]
    public void Setup()
    {
        // Р ВҳРЎРғР С—Р С•Р В»РЎРҠР В·РЎС“Р ВөР Сҳ Р РҶРЎРӮР ВөР СҳР ВөР Р…Р Р…РЎС“РЎРӢ Р С—Р В°Р С—Р С”РЎС“ Р Т‘Р В»РЎРҸ РЎвҖҡР ВөРЎРғРЎвҖҡР С•Р РҶ Р Р…Р В°РЎРғРЎвҖҡРЎРӮР С•Р ВөР С”
        testSettingsPath = Path.Combine(Path.GetTempPath(), "PairCheckerSettingsTests");
        if (Directory.Exists(testSettingsPath))
        {
            Directory.Delete(testSettingsPath, true);
        }
    }

    [TearDown]
    public void Cleanup()
    {
        if (Directory.Exists(testSettingsPath))
        {
            Directory.Delete(testSettingsPath, true);
        }
    }

    [Test]
    public void Load_WhenFileDoesNotExist_ShouldReturnDefaultSettings()
    {
        // Act
        var settings = AppSettings.Load();

        // Assert
        Assert.That(settings, Is.Not.Null);
        Assert.That(settings.LastFolder, Is.EqualTo(string.Empty));
    }

    [Test]
    public void Save_ShouldCreateSettingsFile()
    {
        // Arrange
        var settings = new AppSettings
        {
            LastFolder = ".\\Test",
            LastFirstFormat = ".pdf",
            LastSecondFormat = ".dxf",
            LastRecursive = true
        };

        // Act
        settings.Save();

        // Assert
        var loaded = AppSettings.Load();
        Assert.That(loaded.LastFolder, Is.EqualTo(".\\Test"));
        Assert.That(loaded.LastFirstFormat, Is.EqualTo(".pdf"));
        Assert.That(loaded.LastSecondFormat, Is.EqualTo(".dxf"));
        Assert.That(loaded.LastRecursive, Is.True);
    }
}


